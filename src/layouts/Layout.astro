---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Joséphine Raugel — Brain × AI PhD student (Meta · ENS)",
  description = "Joséphine Raugel — PhD student at Meta AI and ENS, working on brain–AI alignment and neural decoding.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Joséphine Raugel" />
    <link rel="canonical" href="https://jraugel.github.io/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jraugel.github.io/" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Optimistic+Display:wght@500;700&family=Playfair+Display:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script is:inline>
      // ─── Missing-media fallback ─────────────────────────────────────────
      function mkPlaceholder(msg) {
        const div = document.createElement("div");
        div.className = "media-placeholder";
        div.textContent = msg || "Missing media — see ASSETS.md";
        return div;
      }
      document
        .querySelectorAll(".pub-illustration img")
        .forEach((img) => {
          img.addEventListener("error", () => {
            img.replaceWith(mkPlaceholder(img.dataset.fallback));
          });
        });
      document.querySelectorAll(".pub-illustration video").forEach((v) => {
        v.addEventListener(
          "error",
          () => v.replaceWith(mkPlaceholder(v.dataset.fallback)),
          true,
        );
        queueMicrotask(() => {
          if (v.networkState === HTMLMediaElement.NETWORK_NO_SOURCE) {
            v.replaceWith(mkPlaceholder(v.dataset.fallback));
          }
        });
      });

      // ─── Video modal (YouTube + iframe) ─────────────────────────────────
      const modal = document.getElementById("vmodal");
      const modalContent = document.getElementById("vmodal-content");
      const modalClose = document.getElementById("vmodal-close");

      function toEmbed(url) {
        // YouTube → embed URL with autoplay
        try {
          const u = new URL(url);
          const host = u.hostname.replace(/^www\./, "");
          if (host === "youtube.com" || host === "m.youtube.com") {
            const vid = u.searchParams.get("v");
            if (vid)
              return `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0`;
          }
          if (host === "youtu.be") {
            const vid = u.pathname.slice(1);
            if (vid)
              return `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0`;
          }
        } catch (_) {}
        return url; // fall back to raw URL for frame.io, etc.
      }

      function openModal(url) {
        if (!modal || !modalContent) return;
        const embed = toEmbed(url);
        modalContent.innerHTML = `<iframe src="${embed}" title="video" frameborder="0" allow="autoplay; fullscreen; encrypted-media; picture-in-picture" allowfullscreen loading="lazy"></iframe>`;
        modal.classList.add("open");
        document.body.style.overflow = "hidden";
      }
      function closeModal() {
        if (!modal || !modalContent) return;
        modal.classList.remove("open");
        modalContent.innerHTML = "";
        document.body.style.overflow = "";
      }

      document.querySelectorAll(".thumb-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const href = btn.getAttribute("data-video-href");
          if (href) openModal(href);
        });
      });

      if (modalClose) modalClose.addEventListener("click", closeModal);
      if (modal)
        modal.addEventListener("click", (e) => {
          if (e.target === modal) closeModal();
        });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });
    </script>
  </body>
</html>
